<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mart 16 · 광고 채널 딥다이브</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="mart_common.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin:20px 0; }
  .grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin:20px 0; }
  .grid-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin:20px 0; }
  .card { background:#fff; border:1px solid var(--border); border-radius:12px; padding:20px; box-shadow:var(--shadow-sm); }
  .card h3 { font-size:15px; font-weight:700; margin-bottom:12px; color:var(--text); }
  .kpi { font-size:22px; font-weight:800; color:var(--primary); }
  .kpi-label { font-size:12px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:.5px; }
  .kpi-sub { font-size:11px; color:var(--text-secondary); margin-top:4px; }
  .chart-wrap { position:relative; height:280px; }
  table.channel-table { width:100%; border-collapse:collapse; font-size:13px; }
  table.channel-table th { background:#f8fafc; padding:10px 12px; text-align:left; font-weight:600; color:var(--text-secondary); border-bottom:1px solid var(--border); position:sticky; top:0; }
  table.channel-table td { padding:10px 12px; border-bottom:1px solid #f1f5f9; }
  table.channel-table tr:hover { background:#f8fafc; }
  .num { text-align:right; font-variant-numeric:tabular-nums; }
  .badge-good { background:#dcfce7; color:#15803d; padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600; }
  .badge-bad  { background:#fee2e2; color:#b91c1c; padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600; }
  .badge-warn { background:#fef3c7; color:#a16207; padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600; }
  .tabs { display:flex; gap:8px; margin:16px 0; }
  .tab { padding:8px 16px; border-radius:8px; background:#f1f5f9; cursor:pointer; font-size:13px; font-weight:600; }
  .tab.active { background:var(--primary); color:white; }
</style>
</head>
<body>
<header class="topbar">
  <a href="index.html" class="logo"><span class="logo-mark">D</span>D2C Analytics</a>
  <nav class="crumbs">Dashboard / Growth Analytics / <b>Mart 16 · 광고 채널 딥다이브</b></nav>
</header>

<main class="wrap">
  <h1>Mart 16 · 광고 채널 딥다이브</h1>
  <p class="sub">UTM 소스·매체·캠페인·소재·기기별 <b>유입 품질과 퍼널 전환</b>을 분해합니다.
     (CAC·ROAS는 <a href="mart17.html">Mart 17</a>에서 확인)</p>

  <div class="filter-bar">
    <label>기간</label>
    <input type="date" id="dateFrom">
    <span>~</span>
    <input type="date" id="dateTo">
    <button class="btn" onclick="setRange(7);loadData()">최근 7일</button>
    <button class="btn" onclick="setRange(14);loadData()">최근 14일</button>
    <button class="btn" onclick="setRange(30);loadData()">최근 30일</button>
    <button class="btn primary" onclick="loadData()">적용</button>
  </div>

  <!-- KPI 4개 -->
  <div class="grid-4">
    <div class="card">
      <div class="kpi-label">총 세션</div>
      <div class="kpi" id="kSessions">-</div>
      <div class="kpi-sub" id="kUsers">-</div>
    </div>
    <div class="card">
      <div class="kpi-label">신규 획득 유저</div>
      <div class="kpi" id="kAcquired">-</div>
      <div class="kpi-sub">첫 방문 유저 수</div>
    </div>
    <div class="card">
      <div class="kpi-label">평균 세션 CVR</div>
      <div class="kpi" id="kCvr">-</div>
      <div class="kpi-sub" id="kPurchases">-</div>
    </div>
    <div class="card">
      <div class="kpi-label">총 매출 / AOV</div>
      <div class="kpi" id="kRevenue">-</div>
      <div class="kpi-sub" id="kAov">-</div>
    </div>
  </div>

  <!-- 채널별 점유율 -->
  <div class="grid-2">
    <div class="card">
      <h3>📊 채널별 세션 점유율</h3>
      <div class="chart-wrap"><canvas id="chSessions"></canvas></div>
    </div>
    <div class="card">
      <h3>💰 채널별 매출 점유율</h3>
      <div class="chart-wrap"><canvas id="chRevenue"></canvas></div>
    </div>
  </div>

  <!-- 퍼널 -->
  <div class="card">
    <h3>🎯 채널별 퍼널 (세션 → 장바구니 → 결제 → 구매)</h3>
    <div class="chart-wrap" style="height:320px"><canvas id="chFunnel"></canvas></div>
  </div>

  <!-- 기기별 & 소재별 -->
  <div class="grid-2">
    <div class="card">
      <h3>📱 기기별 세션·매출</h3>
      <div class="chart-wrap"><canvas id="chDevice"></canvas></div>
    </div>
    <div class="card">
      <h3>🎨 소재(ad_content)별 성과 TOP 8</h3>
      <div class="chart-wrap"><canvas id="chAdContent"></canvas></div>
    </div>
  </div>

  <!-- 상세 테이블 (탭 전환) -->
  <div class="card">
    <div class="tabs">
      <div class="tab active" onclick="switchTab('channel')">채널별</div>
      <div class="tab" onclick="switchTab('campaign')">캠페인별</div>
      <div class="tab" onclick="switchTab('creative')">소재별</div>
      <div class="tab" onclick="switchTab('device')">기기별</div>
    </div>
    <div style="max-height:600px; overflow:auto;">
      <table class="channel-table">
        <thead id="thead"></thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>
</main>

<script>
const KRW = n => (n||0).toLocaleString('ko-KR') + '원';
const NUM = n => (n||0).toLocaleString('ko-KR');
const PCT = n => (n==null || isNaN(n)) ? '-' : n.toFixed(2)+'%';

function setRange(days){
  const to = new Date(); to.setHours(0,0,0,0);
  const from = new Date(); from.setDate(to.getDate()-days+1);
  const fmt = d => d.toISOString().slice(0,10);
  document.getElementById('dateFrom').value = fmt(from);
  document.getElementById('dateTo').value   = fmt(to);
}
setRange(7);

let charts = {};
let rowsAll = [];
let currentTab = 'channel';

function destroyChart(id){ if(charts[id]){ charts[id].destroy(); delete charts[id]; } }

function drawPie(id, labels, data){
  destroyChart(id);
  charts[id] = new Chart(document.getElementById(id), {
    type:'doughnut',
    data:{ labels, datasets:[{ data, backgroundColor:['#2563eb','#7c3aed','#ec4899','#f59e0b','#10b981','#06b6d4','#64748b','#f43f5e'] }] },
    options:{ plugins:{legend:{position:'right',labels:{font:{size:11}}}} }
  });
}
function drawStackBar(id, labels, sessions, carts, checkouts, purchases){
  destroyChart(id);
  charts[id] = new Chart(document.getElementById(id), {
    type:'bar',
    data:{ labels, datasets:[
      { label:'세션',    data:sessions,  backgroundColor:'#93c5fd' },
      { label:'장바구니', data:carts,     backgroundColor:'#3b82f6' },
      { label:'결제시작', data:checkouts, backgroundColor:'#1d4ed8' },
      { label:'구매',    data:purchases, backgroundColor:'#059669' }
    ]},
    options:{ plugins:{legend:{position:'top'}}, scales:{y:{beginAtZero:true}} }
  });
}
function drawDeviceBar(id, labels, sessions, revenue){
  destroyChart(id);
  charts[id] = new Chart(document.getElementById(id), {
    type:'bar',
    data:{ labels, datasets:[
      { label:'세션', data:sessions, backgroundColor:'#3b82f6', yAxisID:'y' },
      { label:'매출', data:revenue,  backgroundColor:'#10b981', yAxisID:'y1' }
    ]},
    options:{
      plugins:{legend:{position:'top'}},
      scales:{
        y:  { position:'left',  beginAtZero:true, title:{display:true,text:'세션'} },
        y1: { position:'right', beginAtZero:true, title:{display:true,text:'매출(원)'}, grid:{drawOnChartArea:false} }
      }
    }
  });
}
function drawAdContent(id, labels, sessions, revenue){
  destroyChart(id);
  charts[id] = new Chart(document.getElementById(id), {
    type:'bar',
    data:{ labels, datasets:[
      { label:'세션', data:sessions, backgroundColor:'#7c3aed' },
      { label:'매출/1000', data:revenue.map(r=>r/1000), backgroundColor:'#f59e0b' }
    ]},
    options:{ indexAxis:'y', plugins:{legend:{position:'top'}}, scales:{x:{beginAtZero:true}} }
  });
}
function qualityBadge(cvr, atc){
  if(cvr>=2 && atc>=15) return '<span class="badge-good">우수</span>';
  if(cvr<0.5 && atc<5)  return '<span class="badge-bad">약함</span>';
  return '<span class="badge-warn">보통</span>';
}

function aggregate(rows, keyFn){
  const map = {};
  rows.forEach(r => {
    const k = keyFn(r);
    if(!map[k]) map[k] = { key:k, sessions:0, users:0, acquired:0, page_views:0, carts:0, checkouts:0, purchases:0, revenue:0 };
    const c = map[k];
    c.sessions   += +r.sessions||0;
    c.users      += +r.users||0;
    c.acquired   += +r.acquired_users||0;
    c.page_views += +r.page_views||0;
    c.carts      += +r.add_to_carts||0;
    c.checkouts  += +r.checkouts||0;
    c.purchases  += +r.purchases||0;
    c.revenue    += +r.revenue||0;
  });
  return Object.values(map);
}

function switchTab(tab){
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  event && event.target && event.target.classList.add('active');
  renderTable();
}

function renderTable(){
  const from = document.getElementById('dateFrom').value;
  const to   = document.getElementById('dateTo').value;
  const rows = rowsAll.filter(r => r.event_date>=from && r.event_date<=to);

  let agg, columns;
  if(currentTab==='channel'){
    agg = aggregate(rows, r => `${r.source||'(direct)'} / ${r.medium||'(none)'}`);
    columns = ['채널','세션','유저','신규','페이지뷰','장바구니','결제','구매','CVR','매출','ARPU','품질'];
  } else if(currentTab==='campaign'){
    agg = aggregate(rows, r => r.campaign||'(not set)');
    columns = ['캠페인','세션','유저','신규','페이지뷰','장바구니','결제','구매','CVR','매출','ARPU','품질'];
  } else if(currentTab==='creative'){
    agg = aggregate(rows, r => r.ad_content||'(not_set)');
    columns = ['소재','세션','유저','신규','페이지뷰','장바구니','결제','구매','CVR','매출','ARPU','품질'];
  } else {
    agg = aggregate(rows, r => r.device_category||'unknown');
    columns = ['기기','세션','유저','신규','페이지뷰','장바구니','결제','구매','CVR','매출','ARPU','품질'];
  }

  document.getElementById('thead').innerHTML =
    '<tr>' + columns.map((c,i)=> i===0 ? `<th>${c}</th>` : `<th class="num">${c}</th>`).join('') + '<th>품질</th></tr>';

  document.getElementById('tbody').innerHTML = agg
    .sort((a,b)=>b.revenue-a.revenue || b.sessions-a.sessions)
    .map(r => {
      const cvr = r.sessions ? (r.purchases/r.sessions*100) : 0;
      const atc = r.sessions ? (r.carts/r.sessions*100) : 0;
      const arpu = r.users ? Math.round(r.revenue/r.users) : 0;
      return `<tr>
        <td>${r.key}</td>
        <td class="num">${NUM(r.sessions)}</td>
        <td class="num">${NUM(r.users)}</td>
        <td class="num">${NUM(r.acquired)}</td>
        <td class="num">${NUM(r.page_views)}</td>
        <td class="num">${NUM(r.carts)}</td>
        <td class="num">${NUM(r.checkouts)}</td>
        <td class="num">${NUM(r.purchases)}</td>
        <td class="num">${PCT(cvr)}</td>
        <td class="num">${KRW(r.revenue)}</td>
        <td class="num">${KRW(arpu)}</td>
        <td>${qualityBadge(cvr,atc)}</td>
      </tr>`;
    }).join('');
}

async function loadData(){
  const from = document.getElementById('dateFrom').value;
  const to   = document.getElementById('dateTo').value;
  try{
    const res = await fetch('data/mart16_ad_channel.json', { cache:'no-cache' });
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    rowsAll = await res.json();
    const rows = rowsAll.filter(r => r.event_date>=from && r.event_date<=to);

    // KPI 계산
    const totalSess = rows.reduce((s,r)=>s+(+r.sessions||0),0);
    const totalUsers= rows.reduce((s,r)=>s+(+r.users||0),0);
    const totalAcq  = rows.reduce((s,r)=>s+(+r.acquired_users||0),0);
    const totalPurc = rows.reduce((s,r)=>s+(+r.purchases||0),0);
    const totalRev  = rows.reduce((s,r)=>s+(+r.revenue||0),0);
    document.getElementById('kSessions').textContent = NUM(totalSess);
    document.getElementById('kUsers').textContent    = `순 유저 ${NUM(totalUsers)}`;
    document.getElementById('kAcquired').textContent = NUM(totalAcq);
    document.getElementById('kCvr').textContent      = totalSess ? PCT(totalPurc/totalSess*100) : '-';
    document.getElementById('kPurchases').textContent= `구매 ${NUM(totalPurc)}건`;
    document.getElementById('kRevenue').textContent  = KRW(totalRev);
    document.getElementById('kAov').textContent      = totalPurc ? `AOV ${KRW(Math.round(totalRev/totalPurc))}` : 'AOV -';

    // 채널 도넛
    const chAgg = aggregate(rows, r => `${r.source||'(direct)'} / ${r.medium||'(none)'}`)
      .sort((a,b)=>b.sessions-a.sessions).slice(0,8);
    drawPie('chSessions', chAgg.map(x=>x.key), chAgg.map(x=>x.sessions));
    drawPie('chRevenue',  chAgg.map(x=>x.key), chAgg.map(x=>x.revenue));

    // 퍼널
    drawStackBar('chFunnel', chAgg.map(x=>x.key),
      chAgg.map(x=>x.sessions), chAgg.map(x=>x.carts),
      chAgg.map(x=>x.checkouts), chAgg.map(x=>x.purchases));

    // 기기별
    const devAgg = aggregate(rows, r => r.device_category||'unknown');
    drawDeviceBar('chDevice', devAgg.map(x=>x.key),
      devAgg.map(x=>x.sessions), devAgg.map(x=>x.revenue));

    // 소재별 TOP 8
    const adAgg = aggregate(rows, r => r.ad_content||'(not_set)')
      .filter(x => x.sessions>=2).sort((a,b)=>b.sessions-a.sessions).slice(0,8);
    drawAdContent('chAdContent', adAgg.map(x=>x.key),
      adAgg.map(x=>x.sessions), adAgg.map(x=>x.revenue));

    renderTable();
  }catch(e){
    console.error(e);
    document.getElementById('tbody').innerHTML =
      `<tr><td colspan="12" style="padding:24px;text-align:center;color:#b91c1c">
        데이터 로딩 실패: ${e.message}</td></tr>`;
  }
}
loadData();
</script>
</body>
</html>
